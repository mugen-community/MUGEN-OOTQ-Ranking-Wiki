  "naming_rule": {
    "case": {
      "zh": "帕斯卡命名法",
      "en": "PascalCase",
      "ja": "パスカルケース"
    },
    "format": {
      "zh": "标准英文短语",
      "en": "Standard English Phrase",
      "ja": "標準英語フレーズ"
    },
    "multilang_supported": true,
    "description": {
      "zh": "仅存储分级（tier_system）、启动技术（trigger_technique）、攻击技术（attack_technique）、效果技术（effect_technique）四类规范化标签，值字段支持多语言（zh/en/ja）",
      "en": "Only stores four standardized categories: tier (tier_system), trigger (trigger_technique), attack (attack_technique), effect (effect_technique). Value fields support multilingual (zh/en/ja)",
      "ja": "格付け（tier_system）、起動技術（trigger_technique）、攻撃技術（attack_technique）、効果技術（effect_technique）の4つのカテゴリのみを保存。値フィールドは多言語（zh/en/ja）をサポート"
    }
  },

