<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>编辑 - <%= title %></title>
  <link rel="stylesheet" href="styles.css">
  <script src="i18n.js" defer></script>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="" class="logo">
        <span>📃</span>
        <span>MUGEN OOTQ Wiki</span>
      </a>
      <div class="header-controls">
        <button id="themeToggle" class="btn" aria-label="Toggle theme">🌙</button>
        <select id="langSelect" class="lang-select">
          <option value="zh">中文</option>
          <option value="en">English</option>
          <option value="ja">日本語</option>
        </select>
      </div>
    </div>
  </header>

  <nav class="container">
    <div style="padding: 10px 0; border-bottom: 1px solid var(--border-color);">
      <a href="" data-i18n="home">首页</a>
      <a href="characters/" data-i18n="characters" style="margin-left: 20px;">角色</a>
      <a href="glossary/" data-i18n="glossary" style="margin-left: 20px;">术语</a>
    </div>
  </nav>

  <main class="container">
    <div class="page-header">
      <h1>Issue CMS 草稿生成器</h1>
      <p class="lead">填写角色信息后，会生成可直接粘贴到 GitHub Issue 的 JSON 代码块。</p>
    </div>

    <div class="format-hint">
      <h3>数据格式说明</h3>
      <ul>
        <li>Issue 正文须包含一个 <code>```json</code> 代码块，内含角色元数据 JSON。</li>
        <li><strong>summary</strong> / <strong>description</strong> 等文本字段支持 <strong>HTML</strong> 和 <strong>GitHub Flavored Markdown</strong>，页面会自动渲染。</li>
        <li>多语言字段使用 <code>{ "zh": "...", "en": "...", "ja": "..." }</code> 格式。</li>
        <li>必填标签：<code>character</code>；辅助标签：<code>slug:&lt;slug&gt;</code>、<code>tier:low|mid|high|top</code>、<code>level:&lt;text&gt;</code>。</li>
        <li><strong>images</strong>：预览图/头像，支持 URL 或 <code>&lt;!-- image:N --&gt;</code> 引用 Issue 正文中上传的图片。</li>
        <li><strong>detailImages</strong>：介绍图，支持 URL 或 <code>&lt;!-- image:N --&gt;</code> 引用 Issue 正文中上传的图片。</li>
        <li>图片索引从 1 开始，按 Issue 正文中图片出现顺序计数。</li>
        <li>JSON 代码块之外的 Issue 正文内容会作为描述回退显示。</li>
      </ul>
    </div>

    <div class="edit-form">
      <div class="form-group">
        <label>Slug (建议与角色页面 URL 标识一致)</label>
        <input type="text" id="slug" placeholder="例如: my-character">
      </div>

      <div class="form-group">
        <label>标题</label>
        <input type="text" id="title" placeholder="例如: My Character">
      </div>

      <div class="form-group">
        <label>摘要</label>
        <textarea id="summary" placeholder="简短摘要"></textarea>
      </div>

      <div class="form-group">
        <label>OOTQ Tier</label>
        <select id="ootqTier">
          <option value="low">low</option>
          <option value="mid">mid</option>
          <option value="high">high</option>
          <option value="top">top</option>
        </select>
      </div>

      <div class="form-group">
        <label>OOTQ Level (展示文本)</label>
        <input type="text" id="ootqLevel" placeholder="例如: 论外下位C / Out-of-Topic Low C">
      </div>

      <div class="form-group">
        <label>作者</label>
        <input type="text" id="author" placeholder="例如: Foo, Bar">
      </div>

      <div class="form-group">
        <label>来源</label>
        <input type="text" id="origin" placeholder="例如: MUGEN">
      </div>

      <div class="form-group">
        <label>启动方式 (逗号分隔)</label>
        <input type="text" id="activation" placeholder="例如: %n启动, StateDef溢出">
      </div>

      <div class="form-group">
        <label>技术 (逗号分隔)</label>
        <input type="text" id="techniques" placeholder="例如: LIFE改写, Noko解除">
      </div>

      <div class="form-group">
        <label>标签 (逗号分隔)</label>
        <input type="text" id="tags" placeholder="例如: 参考, 论外下位, C级">
      </div>

      <div class="form-group">
        <label>预览图 / 头像 (逗号分隔，支持 URL 或 <!-- image:N --> 引用)</label>
        <input type="text" id="images" placeholder="例如: <!-- image:1 --> 或 https://.../cover.png">
      </div>

      <div class="form-group">
        <label>介绍图 (逗号分隔，用于详情页，支持 URL 或 <!-- image:N --> 引用)</label>
        <input type="text" id="detailImages" placeholder="例如: <!-- image:2 -->, <!-- image:3 -->">
      </div>

      <div class="form-group">
        <label>下载链接</label>
        <input type="text" id="downloadUrl" placeholder="例如: https://example.com/character.zip">
      </div>

      <div class="form-group">
        <label>详细描述 (支持 HTML 或 GitHub Markdown)</label>
        <textarea id="description" rows="8" placeholder="角色详细描述..."></textarea>
      </div>

      <div class="form-actions">
        <button id="generateBtn" class="btn btn-primary" type="button">生成 Issue 草稿</button>
      </div>

      <div id="jsonPreview" class="json-preview" style="display:none;">
        <h3>复制以下内容到 Issue 正文</h3>
        <pre><code id="jsonOutput"></code></pre>
        <div class="form-actions">
          <a id="issueBtn" href="#" target="_blank" rel="noopener" class="btn btn-primary">打开 GitHub 新建 Issue</a>
          <button id="copyBtn" class="btn" type="button">复制草稿</button>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2026 MUGEN OOTQ Ranking Wiki</p>
    </div>
  </footer>

  <script>
(function () {
  const issueBase = 'https://github.com/mugen-community/MUGEN-OOTQ-Ranking-Wiki/issues/new?template=character_submission.md';

  function splitList(id) {
    return document.getElementById(id).value
      .split(',')
      .map((item) => item.trim())
      .filter(Boolean);
  }

  function buildMeta() {
    const slug = document.getElementById('slug').value.trim();
    const title = document.getElementById('title').value.trim();
    if (!title) {
      alert('请先填写标题');
      return null;
    }

    const summary = document.getElementById('summary').value.trim();
    const ootqTier = document.getElementById('ootqTier').value;
    const ootqLevel = document.getElementById('ootqLevel').value.trim();
    const author = document.getElementById('author').value.trim();
    const origin = document.getElementById('origin').value.trim();
    const activation = splitList('activation');
    const techniques = splitList('techniques');
    const tags = splitList('tags');
    const images = splitList('images');
    const detailImages = splitList('detailImages');
    const downloadUrl = document.getElementById('downloadUrl').value.trim();
    const description = document.getElementById('description').value.trim();

    const meta = {
      slug,
      title: { zh: title, en: title, ja: title },
      summary: { zh: summary, en: summary, ja: summary },
      ootqTier,
      ootqLevel: ootqLevel ? { zh: ootqLevel, en: ootqLevel, ja: ootqLevel } : undefined,
      origin: origin || undefined,
      author: author || undefined,
      activation: activation.length ? activation : undefined,
      techniques: techniques.length ? techniques : undefined,
      tags: tags.length ? { zh: tags, en: tags, ja: tags } : undefined,
      images: images.length ? images : undefined,
      detailImages: detailImages.length ? detailImages : undefined,
      downloadUrl: downloadUrl || undefined,
      description: description ? { zh: description, en: description, ja: description } : undefined
    };

    Object.keys(meta).forEach((key) => {
      if (meta[key] === undefined || meta[key] === '') delete meta[key];
    });

    return meta;
  }

  function renderDraft() {
    const meta = buildMeta();
    if (!meta) return;

    const title = typeof meta.title === 'object' ? (meta.title.zh || 'Untitled') : (meta.title || 'Untitled');
    const body = [
      '```json',
      JSON.stringify(meta, null, 2),
      '```'
    ].join('\n');

    document.getElementById('jsonOutput').textContent = body;
    document.getElementById('jsonPreview').style.display = 'block';

    const url = new URL(issueBase);
    url.searchParams.set('title', '[character] ' + title);
    url.searchParams.set('body', body);

    const labels = [];
    if (meta.slug) labels.push('slug:' + meta.slug);
    labels.push('tier:' + (meta.ootqTier || 'low'));
    url.searchParams.set('labels', labels.join(','));

    document.getElementById('issueBtn').href = url.toString();
  }

  document.getElementById('generateBtn').addEventListener('click', renderDraft);

  document.getElementById('copyBtn').addEventListener('click', function () {
    const text = document.getElementById('jsonOutput').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const old = this.textContent;
      this.textContent = '已复制';
      setTimeout(() => {
        this.textContent = old;
      }, 1200);
    });
  });

  document.getElementById('title').addEventListener('input', function () {
    const slugInput = document.getElementById('slug');
    if (!slugInput.value.trim()) {
      slugInput.value = this.value
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
  });
})();
  </script>

  <style>
.edit-form {
  max-width: 780px;
  margin: 0 auto;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 24px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: var(--text-primary);
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--border-color);
  border-radius: 6px;
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 1em;
  font-family: inherit;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  outline: none;
  border-color: var(--link-color);
}

.form-group textarea {
  resize: vertical;
  min-height: 100px;
}

.form-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.btn-primary {
  background: var(--link-color);
  color: #fff;
  border: none;
  padding: 10px 20px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1em;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
}

.btn-primary:hover {
  opacity: 0.92;
  text-decoration: none;
}

.json-preview {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-color);
}

.json-preview h3 {
  margin-bottom: 12px;
  font-size: 1.1em;
}

.json-preview pre {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 16px;
  overflow-x: auto;
  max-height: 420px;
}

.json-preview code {
  font-family: Consolas, Monaco, monospace;
  font-size: 0.9em;
  white-space: pre;
}

.format-hint {
  max-width: 780px;
  margin: 0 auto 20px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 16px 20px;
  font-size: 0.92em;
}

.format-hint h3 {
  margin: 0 0 8px;
  font-size: 1em;
}

.format-hint ul {
  margin: 0;
  padding-left: 20px;
}

.format-hint li {
  margin-bottom: 6px;
  line-height: 1.5;
}

.format-hint code {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 3px;
  padding: 1px 5px;
  font-size: 0.88em;
  font-family: Consolas, Monaco, monospace;
}
  </style>
</body>
</html>
