<div class="character-page">
  <nav class="breadcrumb">
    <a href="<%= r('') %>" data-i18n="home">首页</a>
    <span>›</span>
    <a href="<%= r('characters/') %>" data-i18n="characters">角色</a>
    <span>›</span>
    <span data-i18n="title"><%= getField(meta.title, 'zh') %></span>
    <span style="flex:1"></span>
    <a href="https://github.com/KYjoke/MUGEN-OOTQ-Ranking-Wiki/edit/main/content/characters/<%= slug %>/meta.json" target="_blank" class="btn" style="padding:4px 10px;font-size:0.85em;" data-i18n="edit">编辑</a>
  </nav>

  <div class="infobox">
    <div class="infobox-header">
      <h1 data-i18n="title"><%= getField(meta.title, 'zh') %></h1>
    </div>
    <% if (meta.image) { %>
      <div class="infobox-image">
        <img src="<%= r('') %>img/<%= meta.image %>" alt="<%= getField(meta.title, 'zh') %>">
      </div>
    <% } else if (hasAssets) { %>
      <div class="infobox-image">
        <img src="<%= r('assets/') %>cover.png" alt="<%= getField(meta.title, 'zh') %>" onerror="this.style.display='none'">
      </div>
    <% } %>
    <table class="infobox-table">
      <% if (meta.ootqLevel) { %>
        <tr><th data-i18n="ootqLevel">OOTQ 等级</th><td><span data-lang='<%= JSON.stringify(meta.ootqLevel).replace(/'/g, "\\'") %>'><%= getField(meta.ootqLevel, 'zh') %></span></td></tr>
      <% } %>
      <% if (meta.author) { %>
        <tr><th data-i18n="author">作者</th><td><%= meta.author %></td></tr>
      <% } %>
      <% if (meta.origin) { %>
        <tr><th data-i18n="origin">作品来源</th><td><%= meta.origin %></td></tr>
      <% } %>
      <% if (meta.activation) { %>
        <tr><th data-i18n="activation">启动方式</th><td><%= meta.activation %></td></tr>
      <% } %>
      <% if (meta.tags && (Array.isArray(meta.tags) ? meta.tags.length : (meta.tags.zh ? meta.tags.zh.length : 0))) { %>
        <tr><th data-i18n="tags">标签</th><td><div class="tags"><% const tagsArr = Array.isArray(meta.tags) ? meta.tags : (meta.tags.zh || []); tagsArr.forEach(tag => { %><span class="tag"><%= getField(tag, 'zh') %></span><% }); %></div></td></tr>
      <% } %>
      <% if (meta.downloadUrl) { %>
        <tr><th data-i18n="download">下载</th><td><a href="<%= meta.downloadUrl %>" target="_blank" rel="noopener" data-i18n="downloadLink">点击下载</a></td></tr>
      <% } %>
    </table>
  </div>

  <div class="article-body">
    <% if (meta.summary) { %>
      <p class="lead" data-i18n="summary"><%= getField(meta.summary, 'zh') %></p>
    <% } %>
    <div data-i18n="description">
      <%- getField(meta.description, 'zh') || '<p class="empty">暂无详细描述</p>' %>
    </div>
  </div>

  <% if (meta.links && meta.links.length) { %>
    <div class="section">
      <h2 data-i18n="relatedLinks">相关链接</h2>
      <ul class="link-list">
        <% meta.links.forEach(link => { %>
          <li><a href="<%= link.url %>" target="_blank" rel="noopener"><%= link.name %></a></li>
        <% }); %>
      </ul>
    </div>
  <% } %>
</div>

<script>
window.__meta = <%- JSON.stringify(meta) %>;
</script>

<style>
.character-page {
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
  align-items: flex-start;
}

.infobox {
  width: 280px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
}

.infobox-header {
  background: var(--bg-card);
  padding: 12px 15px;
  border-bottom: 1px solid var(--border-color);
}

.infobox-header h1 {
  font-size: 1.2em;
  font-weight: 600;
  margin: 0;
  border: none;
  padding: 0;
}

.infobox-image {
  padding: 10px;
  text-align: center;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
}

.infobox-image img {
  max-width: 100%;
  max-height: 250px;
  border-radius: 4px;
}

.infobox-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9em;
}

.infobox-table th,
.infobox-table td {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border-color);
  text-align: left;
}

.infobox-table th {
  background: var(--bg-card);
  font-weight: 500;
  color: var(--text-secondary);
  width: 40%;
}

.infobox-table tr:last-child th,
.infobox-table tr:last-child td {
  border-bottom: none;
}

.article-body {
  flex: 1;
  min-width: 0;
}

.article-body .lead {
  font-size: 1.1em;
  color: var(--text-secondary);
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px solid var(--border-color);
}

.article-body p {
  margin-bottom: 15px;
}

.article-body h2 {
  font-size: 1.3em;
  margin: 25px 0 10px;
  padding-bottom: 5px;
  border-bottom: 1px solid var(--border-color);
}

.article-body h3 {
  font-size: 1.1em;
  margin: 20px 0 8px;
}

.article-body ul,
.article-body ol {
  margin: 15px 0;
  padding-left: 25px;
}

.article-body li {
  margin-bottom: 6px;
}

.section {
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid var(--border-color);
}

.link-list {
  list-style: none;
  padding: 0;
}

.link-list li {
  padding: 6px 0;
}

.link-list li::before {
  content: "→ ";
  color: var(--text-secondary);
}

.empty {
  color: var(--text-secondary);
  font-style: italic;
}

@media (max-width: 700px) {
  .character-page {
    flex-direction: column;
  }

  .infobox {
    width: 100%;
  }
}
</style>
