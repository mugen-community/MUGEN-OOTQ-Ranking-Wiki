<div class="page-header">
  <h1 data-i18n="<%= pageTitle %>"><%= pageTitleZh %></h1>
  <p class="lead" data-i18n="<%= leadKey %>"><%= leadZh %></p>
</div>

<% if (itemType === 'char') { %>
<div class="tag-filter" id="tagFilter">
  <span style="margin-right:8px;font-weight:bold;">强度:</span>
  <button class="tag-btn active" data-tag="all">全部</button>
  <% const allTags = [...new Set(items.flatMap(item => {
    const tags = item.meta.tags;
    return Array.isArray(tags) ? tags.map(t => getField(t, 'zh')) : (tags?.zh || []);
  }))].sort(); %>
  <% allTags.forEach(tag => { %>
    <button class="tag-btn" data-tag="<%= tag %>"><%= tag %></button>
  <% }); %>
</div>
<div class="tag-filter" id="activationFilter">
  <span style="margin-right:8px;font-weight:bold;">启动技术:</span>
  <button class="tag-btn active" data-act="all">全部</button>
  <% const allActs = [...new Set(items.flatMap(item => item.meta.activation ? [item.meta.activation] : []))].sort(); %>
  <% allActs.forEach(act => { %>
    <button class="tag-btn" data-act="<%= act %>"><%= act %></button>
  <% }); %>
</div>
<div class="tag-filter" id="techFilter">
  <span style="margin-right:8px;font-weight:bold;">攻击技术:</span>
  <button class="tag-btn active" data-tech="all">全部</button>
  <% const allTechs = [...new Set(items.flatMap(item => item.meta.techniques || []))].sort(); %>
  <% allTechs.forEach(tech => { %>
    <button class="tag-btn" data-tech="<%= tech %>"><%= tech %></button>
  <% }); %>
</div>
<% } %>

<div class="list-container" id="listContainer" style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;">
  <% items.forEach((item, idx) => { %>
    <a class="card <%= itemType %>-card" href="<%= item.slug %>/" data-tags='<%= JSON.stringify(Array.isArray(item.meta.tags) ? item.meta.tags.map(t => getField(t, 'zh')) : (item.meta.tags?.zh || [])).replace(/'/g, "\\'") %>' data-act='<%= item.meta.activation || "" %>' data-techs='<%= JSON.stringify(item.meta.techniques || []).replace(/'/g, "\\'") %>' style="display:flex;flex-direction:column;padding:16px;">
      <% if (itemType === 'char' && item.meta.image) { %>
        <img src="../img/<%= item.meta.image %>" alt="<%= getField(item.meta.title, 'zh') %>" style="width:100%;height:100px;object-fit:cover;border-radius:4px;margin-bottom:10px;">
      <% } %>
      <div class="card-header">
        <h3 class="card-title" data-lang='<%= JSON.stringify(item.meta.title).replace(/'/g, "\\'") %>'><%= getField(item.meta.title, 'zh') %></h3>
        <% if (itemType === 'char' && item.meta.ootqLevel) { %>
          <span class="ootq-badge ootq-<%= item.meta.ootqTier || 'low' %>" data-lang='<%= JSON.stringify(item.meta.ootqLevel).replace(/'/g, "\\'") %>'><%= getField(item.meta.ootqLevel, 'zh') %></span>
        <% } %>
      </div>
      <% if (item.meta.summary) { %>
        <p class="card-summary" data-lang='<%= JSON.stringify(item.meta.summary).replace(/'/g, "\\'") %>'><%= getField(item.meta.summary, 'zh') %></p>
      <% } %>
      <% if (itemType === 'char' && item.meta.tags) { %>
        <% const tagsArr = Array.isArray(item.meta.tags) ? item.meta.tags : (item.meta.tags.zh || []); %>
        <% if (tagsArr.length) { %>
          <div class="tags">
            <% tagsArr.slice(0, 3).forEach(tag => { %>
              <span class="tag"><%= getField(tag, 'zh') %></span>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    </a>
  <% }); %>
  <% if (items.length === 0) { %>
    <div class="empty-state">
      <p data-i18n="noContent">暂无内容</p>
    </div>
  <% } %>
</div>

<style>
.tag-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 20px 0;
  align-items: center;
}

.tag-btn {
  padding: 6px 14px;
  border: 1px solid var(--border-color);
  border-radius: 16px;
  background: var(--bg-secondary);
  color: var(--text-primary);
  cursor: pointer;
  font-size: 0.9em;
  transition: all 0.2s;
}

.tag-btn:hover {
  border-color: var(--link-color);
}

.tag-btn.active {
  background: var(--link-color);
  color: white;
  border-color: var(--link-color);
}

.list-container .card {
  display: flex;
  flex-direction: column;
  padding: 16px;
}

.list-container .card.hidden {
  display: none;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 6px;
}

.card-title {
  margin: 0;
  color: var(--link-color);
  font-size: 1.1em;
}

.card-summary {
  color: var(--text-secondary);
  font-size: 0.95em;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.list-container .tags {
  margin-top: 8px;
}
</style>

<script>
let currentTag = 'all';
let currentAct = 'all';
let currentTech = 'all';

document.querySelectorAll('#tagFilter .tag-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    currentTag = btn.dataset.tag;
    document.querySelectorAll('#tagFilter .tag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterCards();
  });
});

document.querySelectorAll('#activationFilter .tag-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    currentAct = btn.dataset.act;
    document.querySelectorAll('#activationFilter .tag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterCards();
  });
});

document.querySelectorAll('#techFilter .tag-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    currentTech = btn.dataset.tech;
    document.querySelectorAll('#techFilter .tag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterCards();
  });
});

function filterCards() {
  document.querySelectorAll('#listContainer .card').forEach(card => {
    const tags = JSON.parse(card.dataset.tags || '[]');
    const act = card.dataset.act || '';
    const techs = JSON.parse(card.dataset.techs || '[]');
    const tagMatch = currentTag === 'all' || tags.includes(currentTag);
    const actMatch = currentAct === 'all' || act === currentAct;
    const techMatch = currentTech === 'all' || techs.includes(currentTech);
    card.classList.toggle('hidden', !(tagMatch && actMatch && techMatch));
  });
}
</script>