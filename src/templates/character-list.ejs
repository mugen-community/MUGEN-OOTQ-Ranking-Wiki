<div class="page-header">
  <h1>角色数据库 (Issue CMS)</h1>
  <p class="lead">列表、预览、详情统一在此页面。数据实时来自 GitHub Issues。</p>
</div>

<section class="issue-cms-controls">
  <div class="search-box">
    <input id="searchInput" type="search" placeholder="按角色名、标签、作者搜索...">
  </div>
  <div class="filter-row">
    <label for="tierFilter">分级</label>
    <select id="tierFilter" class="lang-select">
      <option value="all">全部</option>
      <option value="top">论外最上位</option>
      <option value="high">论外上位</option>
      <option value="mid">论外中位</option>
      <option value="low">论外下位</option>
      <option value="unknown">未标注</option>
    </select>
    <button id="reloadBtn" class="btn" type="button">刷新</button>
  </div>
</section>

<section id="loadingState" class="info-box">正在从 GitHub 拉取角色数据...</section>
<section id="errorState" class="info-box" style="display:none;"></section>

<section id="listView" class="section" style="display:none;">
  <div class="section-header">
    <h2>角色列表</h2>
    <span id="resultCount" class="muted"></span>
  </div>
  <div id="cardGrid" class="card-grid"></div>
</section>

<section id="detailView" class="section" style="display:none;"></section>

<script>
(() => {
  const CONFIG = {
    owner: 'mugen-community',
    repo: 'MUGEN-OOTQ-Ranking-Wiki',
    branch: 'main',
    characterLabel: 'character',
    perPage: 100,
    maxPages: 5
  };

  const state = {
    all: [],
    filtered: [],
    loading: false
  };

  const refs = {
    loading: document.getElementById('loadingState'),
    error: document.getElementById('errorState'),
    list: document.getElementById('listView'),
    detail: document.getElementById('detailView'),
    cardGrid: document.getElementById('cardGrid'),
    resultCount: document.getElementById('resultCount'),
    search: document.getElementById('searchInput'),
    tier: document.getElementById('tierFilter'),
    reload: document.getElementById('reloadBtn')
  };

  const tierOrder = { top: 0, high: 1, mid: 2, low: 3, unknown: 4 };

  function escapeHtml(text) {
    return String(text || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function pickLocalized(value) {
    if (typeof value === 'string') return value;
    if (Array.isArray(value)) return value.join(' / ');
    if (!value || typeof value !== 'object') return '';
    const lang = localStorage.getItem('lang') || 'zh';
    return value[lang] || value.zh || value.en || '';
  }

  function normalizeTags(value) {
    if (!value) return [];
    if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
    if (typeof value === 'object') {
      const lang = localStorage.getItem('lang') || 'zh';
      const candidate = value[lang] || value.zh || value.en || [];
      if (Array.isArray(candidate)) return candidate.map((item) => String(item).trim()).filter(Boolean);
      if (typeof candidate === 'string') return candidate.split(',').map((item) => item.trim()).filter(Boolean);
    }
    if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
    return [];
  }

  function normalizeList(value) {
    if (!value) return [];
    if (Array.isArray(value)) return value.map((item) => String(item).trim()).filter(Boolean);
    if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
    return [];
  }

  function slugify(text) {
    return String(text || '')
      .toLowerCase()
      .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .replace(/-{2,}/g, '-');
  }

  function extractJsonMeta(body) {
    const source = body || '';
    const patterns = [
      /```json\s*([\s\S]*?)```/i,
      /```character\s*([\s\S]*?)```/i,
      /<!--\s*meta\s*([\s\S]*?)-->/i
    ];

    for (const pattern of patterns) {
      const match = source.match(pattern);
      if (match && match[1]) {
        try {
          return JSON.parse(match[1].trim());
        } catch (err) {
          // ignore parse failure and continue
        }
      }
    }

    const trimmed = source.trim();
    if (trimmed.startsWith('{') && trimmed.endsWith('}')) {
      try {
        return JSON.parse(trimmed);
      } catch (err) {
        return null;
      }
    }

    return null;
  }

  function extractAllImages(body) {
    const text = body || '';
    const urls = [];

    const htmlRegex = /<img\s[^>]*src=["'](https?:\/\/[^"']+)["']/gi;
    let m;
    while ((m = htmlRegex.exec(text)) !== null) urls.push(m[1]);

    const mdRegex = /!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/gi;
    while ((m = mdRegex.exec(text)) !== null) urls.push(m[1]);

    return urls;
  }

  function buildImageListFromMarkers(metaValue, bodyImages) {
    const list = [];

    if (Array.isArray(metaValue)) {
      metaValue.forEach((v) => {
        const trimmed = String(v).trim();
        if (!trimmed) return;

        const numMatch = trimmed.match(/^<!--\s*image:(\d+)\s*-->$/i);
        if (numMatch) {
          const idx = parseInt(numMatch[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        list.push(trimmed);
      });
    } else if (typeof metaValue === 'string' && metaValue.trim()) {
      const trimmed = metaValue.trim();

      const numMatch = trimmed.match(/^<!--\s*image:(\d+)\s*-->$/i);
      if (numMatch) {
        const idx = parseInt(numMatch[1], 10) - 1;
        if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
        return list;
      }

      list.push(trimmed);
    }

    return list;
  }

  function buildImageList(metaValue, fallbackFromBody) {
    const list = [];

    if (Array.isArray(metaValue)) {
      metaValue.forEach((v) => { if (v && v.trim()) list.push(v.trim()); });
    } else if (typeof metaValue === 'string' && metaValue.trim()) {
      list.push(metaValue.trim());
    }

    if (!list.length && fallbackFromBody) {
      fallbackFromBody.forEach((u) => { if (u && !list.includes(u)) list.push(u); });
    }

    return list;
  }

        const numMatch2 = trimmed.match(/^(\d+)$/);
        if (numMatch2) {
          const idx = parseInt(numMatch2[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        list.push(trimmed);
      });
    } else if (typeof metaValue === 'string' && metaValue.trim()) {
      const trimmed = metaValue.trim();

      const numMatch = trimmed.match(/^<!--\s*image:(\d+)\s*-->$/i);
      if (numMatch) {
        const idx = parseInt(numMatch[1], 10) - 1;
        if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
        return list;
      }

      const numMatch2 = trimmed.match(/^(\d+)$/);
      if (numMatch2) {
        const idx = parseInt(numMatch2[1], 10) - 1;
        if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
        return list;
      }

      list.push(trimmed);
    }

    return list;
  }

  function buildImageList(metaValue, fallbackFromBody) {
    const list = [];

    if (Array.isArray(metaValue)) {
      metaValue.forEach((v) => {
        const trimmed = String(v).trim();
        if (!trimmed) return;

        const numMatch = trimmed.match(/^<!--\s*image:(\d+)\s*-->$/i);
        if (numMatch) {
          const idx = parseInt(numMatch[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        const numMatch2 = trimmed.match(/^(\d+)$/);
        if (numMatch2) {
          const idx = parseInt(numMatch2[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        const numMatch3 = trimmed.match(/^<!--\s*image:(\d+)\s*-->$/i);
        if (numMatch3) {
          const idx = parseInt(numMatch3[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        const numMatch4 = trimmed.match(/^(\d+)$/);
        if (numMatch4) {
          const idx = parseInt(numMatch4[1], 10) - 1;
          if (idx >= 0 && idx < bodyImages.length) list.push(bodyImages[idx]);
          return;
        }

        list.push(trimmed);
      });
    } else if (typeof metaValue === 'string' && metaValue.trim()) {
      list.push(metaValue.trim());
    }

    if (!list.length && fallbackFromBody) {
      fallbackFromBody.forEach((u) => { if (u && !list.includes(u)) list.push(u); });
    }

    return list;
  }

  function readLabel(labels, prefix) {
    const found = (labels || []).find((label) => typeof label.name === 'string' && label.name.toLowerCase().startsWith(prefix));
    if (!found) return '';
    return found.name.slice(prefix.length).trim();
  }

  function inferTier(meta, labels) {
    const fromMeta = String(meta.ootqTier || '').toLowerCase();
    if (['top', 'high', 'mid', 'low'].includes(fromMeta)) return fromMeta;

    const fromLabel = String(readLabel(labels, 'tier:')).toLowerCase();
    if (['top', 'high', 'mid', 'low'].includes(fromLabel)) return fromLabel;

    return 'unknown';
  }

  function inferLevel(meta, labels, tier) {
    if (meta.ootqLevel) return pickLocalized(meta.ootqLevel);
    const levelLabel = readLabel(labels, 'level:');
    if (levelLabel) return levelLabel;
    if (tier === 'unknown') return '未标注';
    return tier.toUpperCase();
  }

  function bodyWithoutJsonBlock(body) {
    return String(body || '')
      .replace(/```json\s*[\s\S]*?```/ig, '')
      .replace(/```character\s*[\s\S]*?```/ig, '')
      .replace(/<!--\s*meta\s*[\s\S]*?-->/ig, '')
      .trim();
  }

  function renderDescription(text) {
    const raw = String(text || '').trim();
    if (!raw) return '<p class="empty">暂无详细描述</p>';

    const noScript = raw.replace(/<script[\s\S]*?>[\s\S]*?<\/script>/ig, '');

    if (typeof marked !== 'undefined' && marked.parse) {
      try {
        return marked.parse(noScript);
      } catch (e) {
        // fallback
      }
    }

    const hasHtml = /<\/?[a-z][\s\S]*>/i.test(noScript);
    if (hasHtml) return noScript;

    return noScript
      .split(/\n{2,}/)
      .map((paragraph) => '<p>' + escapeHtml(paragraph).replace(/\n/g, '<br>') + '</p>')
      .join('');
  }

  function parseCharacter(issue) {
    const meta = extractJsonMeta(issue.body) || {};
    const title = pickLocalized(meta.title) || issue.title || ('Issue #' + issue.number);
    const tier = inferTier(meta, issue.labels);
    const level = inferLevel(meta, issue.labels, tier);
    const slugLabel = readLabel(issue.labels, 'slug:');
    const slug = String(meta.slug || slugLabel || slugify(title) || ('issue-' + issue.number));
    const tags = normalizeTags(meta.tags);
    const activation = normalizeList(meta.activation);
    const techniques = normalizeList(meta.techniques);
    const fallbackBody = bodyWithoutJsonBlock(issue.body);
    const bodyImages = extractAllImages(issue.body);

    const images = buildImageListFromMarkers(meta.image || meta.images, bodyImages);
    const detailImages = buildImageListFromMarkers(meta.detailImages, bodyImages);

    return {
      id: issue.id,
      number: issue.number,
      slug,
      title,
      summary: pickLocalized(meta.summary) || '',
      description: pickLocalized(meta.description) || fallbackBody,
      tier,
      level,
      origin: meta.origin || '',
      author: meta.author || '',
      tags,
      activation,
      techniques,
      downloadUrl: meta.downloadUrl || '',
      images,
      detailImages,
      issueUrl: issue.html_url,
      updatedAt: issue.updated_at
    };
    }

    if (images.length > 1 || detailImages.length > 1) {
      console.log('[Carousel Debug] slug:', slug, 'images:', images, 'detailImages:', detailImages);
    }

    return {
      id: issue.id,
      number: issue.number,
      slug,
      title,
      summary: pickLocalized(meta.summary) || '',
      description: pickLocalized(meta.description) || fallbackBody,
      tier,
      level,
      origin: meta.origin || '',
      author: meta.author || '',
      tags,
      activation,
      techniques,
      downloadUrl: meta.downloadUrl || '',
      images,
      detailImages,
      issueUrl: issue.html_url,
      updatedAt: issue.updated_at
    };
  }

  async function fetchCharacters() {
    const allIssues = [];

    for (let page = 1; page <= CONFIG.maxPages; page += 1) {
      const url = new URL('https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/issues');
      url.searchParams.set('state', 'all');
      url.searchParams.set('labels', CONFIG.characterLabel);
      url.searchParams.set('per_page', String(CONFIG.perPage));
      url.searchParams.set('page', String(page));
      url.searchParams.set('sort', 'updated');
      url.searchParams.set('direction', 'desc');

      const response = await fetch(url.toString(), {
        headers: {
          Accept: 'application/vnd.github+json'
        }
      });

      if (!response.ok) {
        throw new Error('GitHub API 请求失败: HTTP ' + response.status);
      }

      const chunk = await response.json();
      allIssues.push(...chunk.filter((item) => !item.pull_request));
      if (chunk.length < CONFIG.perPage) break;
    }

    return allIssues.map(parseCharacter).sort((a, b) => {
      if (tierOrder[a.tier] !== tierOrder[b.tier]) return tierOrder[a.tier] - tierOrder[b.tier];
      return a.title.localeCompare(b.title, 'zh-Hans-CN');
    });
  }

  function tierClass(tier) {
    return ['top', 'high', 'mid', 'low'].includes(tier) ? tier : 'low';
  }

  function tierText(tier) {
    const map = {
      top: '论外最上位',
      high: '论外上位',
      mid: '论外中位',
      low: '论外下位',
      unknown: '未标注'
    };
    return map[tier] || map.unknown;
  }

  function detailUrl(slug) {
    const url = new URL(window.location.href);
    url.searchParams.set('slug', slug);
    return url.pathname + url.search;
  }

  function renderCards(items) {
    refs.cardGrid.innerHTML = '';

    if (!items.length) {
      refs.cardGrid.innerHTML = '<div class="empty-state">没有匹配角色</div>';
      return;
    }

    const fragment = document.createDocumentFragment();

    for (const item of items) {
      const card = document.createElement('article');
      card.className = 'card issue-card';
      card.style.cursor = 'pointer';

      card.innerHTML = [
        item.images.length ? '<img class="issue-thumb" src="' + escapeHtml(item.images[0]) + '" alt="' + escapeHtml(item.title) + '">' : '',
        '<div class="issue-head">',
        '<h3>' + escapeHtml(item.title) + '</h3>',
        '<span class="ootq-badge ootq-' + tierClass(item.tier) + '">' + escapeHtml(item.level) + '</span>',
        '</div>',
        item.summary ? '<p class="issue-summary">' + escapeHtml(item.summary) + '</p>' : '<p class="issue-summary muted">暂无摘要</p>',
        item.tags.length ? '<div class="tags">' + item.tags.slice(0, 5).map((tag) => '<span class="tag">' + escapeHtml(tag) + '</span>').join('') + '</div>' : ''
      ].join('');

      card.addEventListener('click', () => openDetail(item.slug));
      fragment.appendChild(card);
    }

    refs.cardGrid.appendChild(fragment);
  }

  function renderMetaRows(item) {
    const rows = [];

    function pushRow(label, value) {
      if (!value) return;
      rows.push('<tr><th>' + escapeHtml(label) + '</th><td>' + value + '</td></tr>');
    }

    pushRow('分级', '<span class="ootq-badge ootq-' + tierClass(item.tier) + '">' + escapeHtml(item.level) + '</span>');
    pushRow('层级', escapeHtml(tierText(item.tier)));
    pushRow('作者', escapeHtml(item.author));
    pushRow('来源', escapeHtml(item.origin));
    pushRow('启动方式', escapeHtml(item.activation.join(' / ')));
    pushRow('技术', escapeHtml(item.techniques.join(' / ')));
    pushRow('标签', item.tags.length ? '<div class="tags">' + item.tags.map((tag) => '<span class="tag">' + escapeHtml(tag) + '</span>').join('') + '</div>' : '');
    pushRow('下载', item.downloadUrl ? '<a href="' + escapeHtml(item.downloadUrl) + '" target="_blank" rel="noopener">下载链接</a>' : '');
    pushRow('Issue', '<a href="' + escapeHtml(item.issueUrl) + '" target="_blank" rel="noopener">#' + item.number + '</a>');

    return rows.join('');
  }

  async function fetchComments(issueNumber) {
    const url = 'https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/issues/' + issueNumber + '/comments?per_page=100';
    const response = await fetch(url, { headers: { Accept: 'application/vnd.github+json' } });
    if (!response.ok) return [];
    return response.json();
  }

  function renderComment(comment) {
    const body = renderDescription(comment.body);
    const date = new Date(comment.created_at).toLocaleString('zh-CN');
    return [
      '<div class="comment-item">',
      '<div class="comment-header">',
      '<img class="comment-avatar" src="' + escapeHtml(comment.user.avatar_url) + '" alt="' + escapeHtml(comment.user.login) + '">',
      '<a class="comment-author" href="' + escapeHtml(comment.user.html_url) + '" target="_blank" rel="noopener">' + escapeHtml(comment.user.login) + '</a>',
      '<span class="comment-date">' + escapeHtml(date) + '</span>',
      '</div>',
      '<div class="comment-body markdown-body">' + body + '</div>',
      '</div>'
    ].join('');
  }

  function renderCarousel(imageList, containerClass) {
    if (!imageList.length) return '';
    const id = 'carousel-' + containerClass + '-' + Math.random().toString(36).slice(2, 8);
    const slides = imageList.map((item, i) => {
      const isHtml = /<img\s/i.test(item);
      const content = isHtml ? item : '<img src="' + escapeHtml(item) + '" alt="" loading="lazy">';
      return '<div class="carousel-slide' + (i === 0 ? ' active' : '') + '">' + content + '</div>';
    }).join('');

    return [
      '<div class="carousel ' + escapeHtml(containerClass) + '" id="' + id + '" data-index="0" data-total="' + imageList.length + '">',
      '<div class="carousel-viewport">' + slides + '</div>',
      imageList.length > 1 ? [
        '<button class="carousel-btn carousel-prev" data-dir="-1" type="button">&#8249;</button>',
        '<button class="carousel-btn carousel-next" data-dir="1" type="button">&#8250;</button>',
        '<span class="carousel-counter">1 / ' + imageList.length + '</span>'
      ].join('') : '',
      '</div>'
    ].join('');
  }

  function renderDetail(item) {
    refs.detail.innerHTML = [
      '<div class="detail-header">',
      '<button class="btn" id="backToList" type="button">返回列表</button>',
      '<a class="btn" href="' + escapeHtml(item.issueUrl) + '" target="_blank" rel="noopener">打开 Issue</a>',
      '</div>',
      '<div class="character-page">',
      '<aside class="infobox">',
      '<div class="infobox-header"><h1>' + escapeHtml(item.title) + '</h1></div>',
      item.images.length ? '<div class="infobox-image">' + renderCarousel(item.images, 'preview') + '</div>' : '',
      '<table class="infobox-table">' + renderMetaRows(item) + '</table>',
      '</aside>',
      '<article class="article-body markdown-body">',
      item.summary ? '<p class="lead">' + escapeHtml(item.summary) + '</p>' : '',
      '<div>' + renderDescription(item.description) + '</div>',
      item.detailImages.length ? '<div class="detail-images">' + renderCarousel(item.detailImages, 'detail') + '</div>' : '',
      '</article>',
      '</div>',
      '<section class="comments-section">',
      '<h2>评论</h2>',
      '<div id="commentsLoading" class="info-box">正在加载评论...</div>',
      '<div id="commentsList"></div>',
      '</section>'
    ].join('');

    refs.detail.querySelectorAll('.carousel-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const carousel = btn.closest('.carousel');
        const dir = parseInt(btn.dataset.dir, 10);
        const total = parseInt(carousel.dataset.total, 10);
        let idx = parseInt(carousel.dataset.index, 10);
        idx = (idx + dir + total) % total;
        carousel.dataset.index = idx;
        carousel.querySelectorAll('.carousel-slide').forEach((s, i) => {
          s.classList.toggle('active', i === idx);
        });
        const counter = carousel.querySelector('.carousel-counter');
        if (counter) counter.textContent = (idx + 1) + ' / ' + total;
      });
    });

    const backBtn = document.getElementById('backToList');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        const url = new URL(window.location.href);
        url.searchParams.delete('slug');
        history.pushState({}, '', url.pathname + url.search);
        renderByRoute();
      });
    }

    fetchComments(item.number).then((comments) => {
      const loading = document.getElementById('commentsLoading');
      const list = document.getElementById('commentsList');
      if (loading) loading.style.display = 'none';
      if (!comments.length) {
        list.innerHTML = '<p class="muted">暂无评论，<a href="' + escapeHtml(item.issueUrl) + '" target="_blank" rel="noopener">前往 GitHub 评论</a></p>';
        return;
      }
      list.innerHTML = comments.map(renderComment).join('');
    }).catch(() => {
      const loading = document.getElementById('commentsLoading');
      const list = document.getElementById('commentsList');
      if (loading) loading.style.display = 'none';
      list.innerHTML = '<p class="muted">评论加载失败</p>';
    });
  }

  function openDetail(slug) {
    history.pushState({}, '', detailUrl(slug));
    renderByRoute();
  }

  function applyFilters() {
    const keyword = refs.search.value.trim().toLowerCase();
    const tier = refs.tier.value;

    state.filtered = state.all.filter((item) => {
      const searchBlob = [
        item.slug,
        item.title,
        item.summary,
        item.author,
        item.origin,
        item.tags.join(' '),
        item.techniques.join(' '),
        item.activation.join(' ')
      ].join(' ').toLowerCase();

      const tierOk = tier === 'all' ? true : item.tier === tier;
      const keywordOk = keyword ? searchBlob.includes(keyword) : true;
      return tierOk && keywordOk;
    });

    refs.resultCount.textContent = '共 ' + state.filtered.length + ' 条';
    renderCards(state.filtered);
  }

  function renderByRoute() {
    const slug = new URLSearchParams(window.location.search).get('slug');

    if (slug) {
      const match = state.all.find((item) => item.slug === slug);
      if (match) {
        refs.list.style.display = 'none';
        refs.detail.style.display = 'block';
        renderDetail(match);
        return;
      }
    }

    refs.detail.style.display = 'none';
    refs.list.style.display = 'block';
    applyFilters();
  }

  function showError(message) {
    refs.loading.style.display = 'none';
    refs.list.style.display = 'none';
    refs.detail.style.display = 'none';
    refs.error.style.display = 'block';
    refs.error.textContent = message;
  }

  async function bootstrap() {
    if (state.loading) return;
    state.loading = true;

    refs.loading.style.display = 'block';
    refs.error.style.display = 'none';

    try {
      state.all = await fetchCharacters();
      refs.loading.style.display = 'none';
      renderByRoute();
    } catch (error) {
