<div class="page-header">
  <h1 data-i18n="characters">角色数据库</h1>
  <p class="lead" data-i18n="charLead">列表、预览、详情统一在此页面。数据实时来自 GitHub Issues。</p>
</div>

<section class="issue-cms-controls">
  <div class="search-box">
    <input id="searchInput" type="search" data-i18n-placeholder="search" placeholder="按角色名、标签搜索...">
  </div>
  <div class="filter-row">
    <label for="tierFilter" data-i18n="tierFilter">分级</label>
    <select id="tierFilter" class="lang-select">
      <option value="all" data-i18n="tierAll">全部</option>
      <option value="top" data-i18n="tierTop">论外最上位</option>
      <option value="high" data-i18n="tierHigh">论外上位</option>
      <option value="mid" data-i18n="tierMid">论外中位</option>
      <option value="low" data-i18n="tierLow">论外下位</option>
      <option value="unknown" data-i18n="tierUnknown">未标注</option>
    </select>
    <button id="reloadBtn" class="btn" type="button" data-i18n="reload">刷新</button>
  </div>
</section>

<section id="loadingState" class="info-box" data-i18n="loading">正在从 GitHub 拉取角色数据...</section>
<section id="errorState" class="info-box" style="display:none;"></section>

<section id="listView" class="section" style="display:none;">
  <div class="section-header">
    <h2 data-i18n="charList">角色列表</h2>
    <span id="resultCount" class="muted"></span>
  </div>
  <div id="cardGrid" class="card-grid"></div>
</section>

<section id="detailView" class="section" style="display:none;"></section>

<script>
(() => {
  const TAG_SYSTEM = <%- JSON.stringify(tagSystem) %>;

  const CONFIG = {
    owner: 'mugen-community',
    repo: 'MUGEN-OOTQ-Ranking-Wiki',
    characterLabel: 'character',
    perPage: 100,
    maxPages: 5
  };

  const tierOrder = { top: 0, high: 1, mid: 2, low: 3, unknown: 4 };
  const tierMap = { Top_Out: 'top', Lower_Out: 'low', Mid_Out: 'mid', Upper_Out: 'high' };

  const defaultLang = (window.__LANGS && window.__LANGS[0]) || 'zh';

  const state = {
    all: null,
    filtered: [],
    tagIndex: null,
    tierKeys: null,
    loading: false,
    lang: defaultLang
  };

  const refs = {
    loading: document.getElementById('loadingState'),
    error: document.getElementById('errorState'),
    list: document.getElementById('listView'),
    detail: document.getElementById('detailView'),
    cardGrid: document.getElementById('cardGrid'),
    resultCount: document.getElementById('resultCount'),
    search: document.getElementById('searchInput'),
    tier: document.getElementById('tierFilter'),
    reload: document.getElementById('reloadBtn')
  };

  function getLang() {
    return localStorage.getItem('lang') || defaultLang;
  }

  function setLang(v) {
    state.lang = v;
    localStorage.setItem('lang', v);
  }

  state.lang = getLang();

  function escapeHtml(text) {
    return String(text || '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function slugify(text) {
    return String(text || '')
      .toLowerCase()
      .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .replace(/-{2,}/g, '-');
  }

  function extractAllImages(body) {
    const urls = [];
    const htmlRe = /<img\s[^>]*src=["'](https?:\/\/[^"']+)["']/gi;
    const mdRe = /!\[[^\]]*\]\((https?:\/\/[^)\s]+)\)/gi;
    let m;
    while ((m = htmlRe.exec(body || '')) !== null) urls.push(m[1]);
    while ((m = mdRe.exec(body || '')) !== null) urls.push(m[1]);
    return urls;
  }

  function buildTagIndex(tagSystem) {
    const index = {};
    const tierKeys = {};
    for (const [category, entries] of Object.entries(tagSystem)) {
      if (category === 'version' || category === 'description' || category === 'naming_rule') continue;
      if (typeof entries !== 'object' || entries === null) continue;
      for (const [key, translations] of Object.entries(entries)) {
        if (typeof translations !== 'object' || translations === null) continue;
        for (const [lang, text] of Object.entries(translations)) {
          if (!text) continue;
          const lower = text.toLowerCase();
          if (!index[lower]) index[lower] = [];
          index[lower].push({ key, category, lang });
        }
        if (category === 'tier_system') {
          tierKeys[key] = translations;
        }
      }
    }
    return { index, tierKeys };
  }

  function scanTags(body, tagIndex) {
    if (!body) return [];
    const lowerBody = body.toLowerCase();
    const found = new Map();
    for (const [lowerText, entries] of Object.entries(tagIndex)) {
      if (lowerBody.includes(lowerText)) {
        for (const entry of entries) {
          if (!found.has(entry.key)) {
            found.set(entry.key, { key: entry.key, category: entry.category });
          }
        }
      }
    }
    return [...found.values()];
  }

  function detectTier(matchedTags, tierKeys) {
    for (const tag of matchedTags) {
      const trans = tierKeys[tag.key];
      if (!trans) continue;
      const prefix = Object.keys(tierMap).find(p => tag.key.startsWith(p));
      return {
        tier: prefix ? tierMap[prefix] : 'unknown',
        level: trans
      };
    }
    return { tier: 'unknown', level: null };
  }

  function getLocalizedSection(body, lang) {
    if (!body) return '';
    const tag = '<!-- ' + lang + ' -->';
    const startIdx = body.indexOf(tag);
    if (startIdx === -1) return body;
    const contentStart = startIdx + tag.length;
    const endIdx = body.indexOf(tag, contentStart);
    if (endIdx === -1) return body;
    return body.slice(contentStart, endIdx).trim();
  }

  function parseCharacter(issue) {
    if (!issue.body || issue.body.length < 10) return null;

    const slug = slugify(issue.title) || ('issue-' + issue.number);
    const images = extractAllImages(issue.body);

    const langs = window.__LANGS || ['zh', 'en', 'ja'];
    const tagsByLang = {};
    const summaryByLang = {};
    const bodyByLang = {};
    let defaultTier = 'unknown';
    let defaultLevel = null;
    for (const lang of langs) {
      const section = getLocalizedSection(issue.body, lang);
      bodyByLang[lang] = section;
      tagsByLang[lang] = scanTags(section, state.tagIndex);
      const bodyText = section.replace(/^#+\s.*$/gm, '').trim();
      summaryByLang[lang] = bodyText.split(/\n{2,}/)[0]
        ?.replace(/\n/g, ' ').replace(/\s+/g, ' ').slice(0, 120).trim() || '';
      if (lang === langs[0]) {
        const tierInfo = detectTier(tagsByLang[lang], state.tierKeys);
        defaultTier = tierInfo.tier;
        defaultLevel = tierInfo.level;
      }
    }

    return {
      id: issue.id,
      number: issue.number,
      slug,
      title: issue.title || ('Issue #' + issue.number),
      body: issue.body,
      images,
      issueUrl: issue.html_url,
      updatedAt: issue.updated_at,
      tagsByLang,
      summaryByLang,
      bodyByLang,
      tier: defaultTier,
      level: defaultLevel
    };
  }

  async function fetchCharacters() {
    const tagIndexData = buildTagIndex(TAG_SYSTEM);
    state.tagIndex = tagIndexData.index;
    state.tierKeys = tagIndexData.tierKeys;

    const allIssues = [];
    for (let page = 1; page <= CONFIG.maxPages; page += 1) {
      const url = new URL('https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/issues');
      url.searchParams.set('state', 'all');
      url.searchParams.set('labels', CONFIG.characterLabel);
      url.searchParams.set('per_page', String(CONFIG.perPage));
      url.searchParams.set('page', String(page));
      url.searchParams.set('sort', 'updated');
      url.searchParams.set('direction', 'desc');
      const response = await fetch(url.toString(), {
        headers: { Accept: 'application/vnd.github+json' }
      });
      if (!response.ok) throw new Error('GitHub API request failed: HTTP ' + response.status);
      const chunk = await response.json();
      allIssues.push(...chunk.filter(item => !item.pull_request));
      if (chunk.length < CONFIG.perPage) break;
    }
    return allIssues.map(parseCharacter).filter(Boolean);
  }

  function tierClass(tier) {
    return ['top', 'high', 'mid', 'low'].includes(tier) ? tier : 'low';
  }

  function detailUrl(slug) {
    const url = new URL(window.location.href);
    url.searchParams.set('slug', slug);
    return url.pathname + url.search;
  }

  function tierLabel(tier, level) {
    const lang = state.lang;
    if (level && typeof level === 'object') return level[lang] || level[defaultLang] || '';
    if (typeof level === 'string') return level;
    return window.__('tierUnknown', state.lang);
  }

  function tagLabel(tag, lang) {
    const entries = TAG_SYSTEM[tag.category];
    if (!entries) return tag.key;
    const trans = entries[tag.key];
    if (!trans) return tag.key;
    return trans[lang] || trans[defaultLang] || tag.key;
  }

  function renderDescription(text) {
    const raw = String(text || '').trim();
    if (!raw) return '<p class="empty">' + window.__('noDetailDesc', state.lang) + '</p>';
    const clean = raw.replace(/<script[\s\S]*?>[\s\S]*?<\/script>/ig, '');
    if (typeof marked !== 'undefined' && marked.parse) {
      try { return marked.parse(clean); } catch (e) {}
    }
    const hasHtml = /<\/?[a-z][\s\S]*>/i.test(clean);
    if (hasHtml) return clean;
    return clean.split(/\n{2,}/).map(p => '<p>' + escapeHtml(p).replace(/\n/g, '<br>') + '</p>').join('');
  }

  function renderCards(items, lang) {
    refs.cardGrid.innerHTML = '';
    if (!items.length) {
      refs.cardGrid.innerHTML = '<div class="empty-state">' + window.__('noMatch', lang) + '</div>';
      return;
    }
    const fragment = document.createDocumentFragment();
    for (const item of items) {
      const card = document.createElement('article');
      card.className = 'card issue-card';
      card.style.cursor = 'pointer';
      const levelText = tierLabel(item.tier, item.level);
      const tags = item.tagsByLang[lang] || [];
      card.innerHTML = [
        item.images.length ? '<img class="issue-thumb" src="' + escapeHtml(item.images[0]) + '" alt="' + escapeHtml(item.title) + '" loading="lazy">' : '',
        '<div class="issue-head">',
        '<h3>' + escapeHtml(item.title) + '</h3>',
        levelText ? '<span class="ootq-badge ootq-' + tierClass(item.tier) + '">' + escapeHtml(levelText) + '</span>' : '',
        '</div>',
        (item.summaryByLang[lang] || item.summaryByLang[defaultLang]) ? '<p class="issue-summary">' + escapeHtml(item.summaryByLang[lang] || item.summaryByLang[defaultLang]) + '</p>' : '',
        tags.length ? '<div class="tags">' + tags.slice(0, 6).map(t => '<span class="tag">' + escapeHtml(tagLabel(t, lang)) + '</span>').join('') + '</div>' : ''
      ].join('');
      card.addEventListener('click', () => openDetail(item.slug));
      fragment.appendChild(card);
    }
    refs.cardGrid.appendChild(fragment);
  }

  async function fetchComments(issueNumber) {
    const url = 'https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/issues/' + issueNumber + '/comments?per_page=100';
    const response = await fetch(url, { headers: { Accept: 'application/vnd.github+json' } });
    if (!response.ok) return [];
    return response.json();
  }

  function renderComment(comment) {
    const body = renderDescription(comment.body);
    const date = new Date(comment.created_at).toLocaleString('zh-CN');
    return [
      '<div class="comment-item">',
      '<div class="comment-header">',
      '<img class="comment-avatar" src="' + escapeHtml(comment.user.avatar_url) + '" alt="' + escapeHtml(comment.user.login) + '">',
      '<a class="comment-author" href="' + escapeHtml(comment.user.html_url) + '" target="_blank" rel="noopener">' + escapeHtml(comment.user.login) + '</a>',
      '<span class="comment-date">' + escapeHtml(date) + '</span>',
      '</div>',
      '<div class="comment-body markdown-body">' + body + '</div>',
      '</div>'
    ].join('');
  }

  function renderDetail(item, lang) {
    const tags = item.tagsByLang[lang] || [];
    const localizedBody = item.bodyByLang[lang] || getLocalizedSection(item.body, lang);
    const levelText = tierLabel(item.tier, item.level);
    refs.detail.innerHTML = [
      '<div class="detail-header">',
      '<button class="btn" id="backToList" type="button">\u2190 ' + window.__('backToList', lang) + '</button>',
      '<a class="btn" href="' + escapeHtml(item.issueUrl) + '" target="_blank" rel="noopener">' + window.__('viewOnGitHub', lang) + ' #' + item.number + '</a>',
      '</div>',
      '<article class="markdown-body">',
      '<h1 class="detail-title">' + escapeHtml(item.title) + '</h1>',
      '<div class="detail-meta">',
      levelText ? '<span class="ootq-badge ootq-' + tierClass(item.tier) + '">' + escapeHtml(levelText) + '</span>' : '',
      tags.length ? ' <span class="tags">' + tags.map(t => '<span class="tag">' + escapeHtml(tagLabel(t, lang)) + '</span>').join('') + '</span>' : '',
      '</div>',
      '<hr class="detail-divider">',
      renderDescription(localizedBody),
      '</article>',
      '<section class="comments-section">',
      '<h2>' + window.__('comments', lang) + '</h2>',
      '<div id="commentsLoading" class="info-box">' + window.__('loadingComments', lang) + '</div>',
      '<div id="commentsList"></div>',
      '</section>'
    ].join('');

    const backBtn = document.getElementById('backToList');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        const url = new URL(window.location.href);
        url.searchParams.delete('slug');
        history.pushState({}, '', url.pathname + url.search);
        renderByRoute();
      });
    }

    fetchComments(item.number).then(comments => {
      const loading = document.getElementById('commentsLoading');
      const list = document.getElementById('commentsList');
      if (loading) loading.style.display = 'none';
      if (!comments.length) {
        list.innerHTML = '<p class="muted">' + window.__('noComments', lang) + '<a href="' + escapeHtml(item.issueUrl) + '" target="_blank" rel="noopener">' + window.__('viewOnGitHub', lang) + '</a></p>';
        return;
      }
      list.innerHTML = comments.map(renderComment).join('');
    }).catch(() => {
      const loading = document.getElementById('commentsLoading');
      const list = document.getElementById('commentsList');
      if (loading) loading.style.display = 'none';
      list.innerHTML = '<p class="muted">' + window.__('commentsFailed', lang) + '</p>';
    });
  }

  function openDetail(slug) {
    history.pushState({}, '', detailUrl(slug));
    renderByRoute();
  }

  function applyFilters(lang) {
    const keyword = refs.search.value.trim().toLowerCase();
    const tierFilter = refs.tier.value;

    state.filtered = state.all.filter(item => {
      const tags = item.tagsByLang[lang] || item.tagsByLang[defaultLang] || [];
      const tagTexts = tags.map(t => tagLabel(t, lang).toLowerCase()).join(' ');
      const searchBlob = [item.slug, item.title, tagTexts].join(' ').toLowerCase();
      const tierOk = tierFilter === 'all' || item.tier === tierFilter;
      const keywordOk = keyword ? searchBlob.includes(keyword) : true;
      return tierOk && keywordOk;
    }).sort((a, b) => {
      if (tierOrder[a.tier] !== tierOrder[b.tier]) return tierOrder[a.tier] - tierOrder[b.tier];
      return a.title.localeCompare(b.title, lang);
    });

    refs.resultCount.textContent = window.__('resultCount', lang).replace('{n}', state.filtered.length);
    renderCards(state.filtered, lang);
  }

  function renderByRoute() {
    if (!state.all) return;
    const lang = state.lang;
    const slug = new URLSearchParams(window.location.search).get('slug');
    if (slug) {
      const match = state.all.find(item => item.slug === slug);
      if (match) {
        refs.list.style.display = 'none';
        refs.detail.style.display = 'block';
        renderDetail(match, lang);
        return;
      }
    }
    refs.detail.style.display = 'none';
    refs.list.style.display = 'block';
    applyFilters(lang);
  }

  function showError(message) {
    refs.loading.style.display = 'none';
    refs.list.style.display = 'none';
    refs.detail.style.display = 'none';
    refs.error.style.display = 'block';
    refs.error.textContent = message;
  }

  async function bootstrap() {
    if (state.loading) return;
    state.loading = true;
    refs.loading.style.display = 'block';
    refs.error.style.display = 'none';
    try {
      state.all = await fetchCharacters();
      refs.loading.style.display = 'none';
      renderByRoute();
    } catch (error) {
      showError(error && error.message ? error.message : window.__('errorLoad', state.lang));
    } finally {
      state.loading = false;
    }
  }

  refs.search.addEventListener('input', () => applyFilters(state.lang));
  refs.tier.addEventListener('change', () => applyFilters(state.lang));
  refs.reload.addEventListener('click', bootstrap);
  document.getElementById('langSelect')?.addEventListener('change', function () {
    setLang(this.value);
    if (state.all) renderByRoute();
  });
  window.addEventListener('popstate', renderByRoute);

  bootstrap();
})();
</script>

<style>
.issue-cms-controls { margin: 10px 0 20px; }
.filter-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
.muted { color: var(--text-secondary); }

.issue-card { display: flex; flex-direction: column; }
.issue-thumb {
  width: 100%; height: 160px; object-fit: cover;
  border-radius: 6px; margin-bottom: 10px; background: var(--bg-secondary);
}
.issue-head { display: flex; justify-content: space-between; gap: 10px; align-items: flex-start; margin-bottom: 8px; }
.issue-head h3 { margin: 0; }
.issue-summary { margin: 0; min-height: 1.5em; font-size: 0.9em; color: var(--text-secondary); }

.detail-header { display: flex; gap: 10px; margin-bottom: 16px; }
.detail-title { margin-top: 0; }
.detail-meta { margin: 8px 0 4px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.detail-divider { margin: 16px 0; }

.comments-section { margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--border-color); }
.comments-section h2 { font-size: 1.2em; font-weight: 500; margin-bottom: 16px; }
.comment-item {
  background: var(--bg-card); border: 1px solid var(--border-color);
  border-radius: 8px; padding: 14px 16px; margin-bottom: 12px;
}
.comment-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.comment-avatar { width: 28px; height: 28px; border-radius: 50%; }
.comment-author { font-weight: 600; font-size: 0.92em; }
.comment-date { color: var(--text-secondary); font-size: 0.82em; }
.comment-body { font-size: 0.94em; }
.empty { color: var(--text-secondary); font-style: italic; }
</style>
