<div class="page-header">
  <h1>角色</h1>
  <p class="lead">所有已收录的角色列表</p>
</div>

<div class="card-grid">
  <% characters.forEach(char => { %>
    <a class="card" href="<%= r('') %><%= char.slug %>/">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">
        <h3 style="margin:0;"><%= char.title %></h3>
        <% if (char.ootqLevel) { %>
          <span class="ootq-badge ootq-<%= char.ootqTier || 'low' %>"><%= char.ootqLevel %></span>
        <% } %>
      </div>
      <% if (char.summary) { %>
        <p><%= char.summary %></p>
      <% } %>
      <% if (char.tags && char.tags.length) { %>
        <div class="tags">
          <% char.tags.slice(0, 4).forEach(tag => { %>
            <span class="tag"><%= tag %></span>
          <% }); %>
        </div>
      <% } %>
    </a>
  <% }); %>
  <% if (characters.length === 0) { %>
    <div class="empty-state">
      <p>暂无角色</p>
    </div>
  <% } %>
</div>
