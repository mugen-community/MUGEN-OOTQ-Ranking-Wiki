<div class="page-header">
  <h1>MUGEN OOTQ Ranking Wiki</h1>
  <div class="search-box">
    <input type="search" id="searchInput" data-i18n-placeholder="search" placeholder="搜索...">
  </div>
</div>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="characters">角色</h2>
    <a href="<%= r('characters/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="charactersGrid">
    <% characters.forEach((char, idx) => { %>
      <a class="card char-card" href="<%= r('characters/') %><%= char.slug %>/">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">
          <h3 class="char-title" data-field="title"><%= getField(char.meta.title, 'zh') %></h3>
          <% if (char.meta.ootqLevel) { %>
            <span class="ootq-badge ootq-<%= char.meta.ootqTier || 'low' %> char-ootq" data-field="ootqLevel"><%= getField(char.meta.ootqLevel, 'zh') %></span>
          <% } %>
        </div>
        <p class="char-summary" data-field="summary"><%= getField(char.meta.summary, 'zh') %></p>
        <% if (char.meta.tags && char.meta.tags.length) { %>
          <div class="tags char-tags" data-field="tags">
            <% (Array.isArray(char.meta.tags) ? char.meta.tags : (char.meta.tags.zh || [])).slice(0, 3).forEach(tag => { %>
              <span class="tag"><%= tag %></span>
            <% }); %>
          </div>
        <% } %>
      </a>
    <% }); %>
    <% if (characters.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无角色</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="glossary">术语</h2>
    <a href="<%= r('glossary/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="glossaryGrid">
    <% terms.forEach(term => { %>
      <a class="card" href="<%= r('glossary/') %><%= term.slug %>/">
        <h3><%= getField(term.meta.title, 'zh') %></h3>
        <% if (term.meta.summary) { %>
          <p><%= getField(term.meta.summary, 'zh') %></p>
        <% } %>
      </a>
    <% }); %>
    <% if (terms.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无术语</p>
      </div>
    <% } %>
  </div>
</section>

<script>
window.__chars = <%- JSON.stringify(characters.map(c => c.meta)) %>;
window.__terms = <%- JSON.stringify(terms.map(t => t.meta)) %>;

function updateCards(lang) {
  document.querySelectorAll('.char-card').forEach((card, i) => {
    const meta = window.__chars[i];
    if (!meta) return;
    
    const titleEl = card.querySelector('.char-title');
    if (titleEl && meta.title) titleEl.textContent = getField(meta.title, lang);
    
    const ootqEl = card.querySelector('.char-ootq');
    if (ootqEl && meta.ootqLevel) ootqEl.textContent = getField(meta.ootqLevel, lang);
    
    const summaryEl = card.querySelector('.char-summary');
    if (summaryEl && meta.summary) summaryEl.textContent = getField(meta.summary, lang);
    
    const tagsEl = card.querySelector('.char-tags');
    if (tagsEl && meta.tags) {
      const tags = meta.tags.map(t => getField(t, lang));
      tagsEl.innerHTML = tags.slice(0, 3).map(t => `<span class="tag">${t}</span>`).join('');
    }
  });
  
  document.querySelectorAll('.glossary-card').forEach((card, i) => {
    const meta = window.__terms[i];
    if (!meta) return;
    
    const titleEl = card.querySelector('.term-title');
    if (titleEl && meta.title) titleEl.textContent = getField(meta.title, lang);
    
    const summaryEl = card.querySelector('.term-summary');
    if (summaryEl && meta.summary) summaryEl.textContent = getField(meta.summary, lang);
  });
}
</script>
