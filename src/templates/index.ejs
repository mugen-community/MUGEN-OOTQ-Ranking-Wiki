<div class="page-header">
  <h1>MUGEN OOTQ Ranking Wiki</h1>
  <div class="search-box">
    <input type="search" id="searchInput" data-i18n-placeholder="search" placeholder="搜索...">
  </div>
</div>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="characters">角色</h2>
    <a href="<%= r('characters/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="charactersGrid">
    <% characters.slice(0, 6).forEach(char => { %>
      <a class="card" href="<%= r('characters/') %><%= char.slug %>/">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">
          <h3 style="margin:0;"><%= char.title %></h3>
          <% if (char.ootqLevel) { %>
            <span class="ootq-badge ootq-<%= char.ootqTier || 'low' %>"><%= char.ootqLevel %></span>
          <% } %>
        </div>
        <% if (char.summary) { %>
          <p><%= char.summary %></p>
        <% } %>
        <% if (char.tags && char.tags.length) { %>
          <div class="tags">
            <% char.tags.slice(0, 3).forEach(tag => { %>
              <span class="tag"><%= tag %></span>
            <% }); %>
          </div>
        <% } %>
      </a>
    <% }); %>
    <% if (characters.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无角色</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="glossary">术语</h2>
    <a href="<%= r('glossary/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="glossaryGrid">
    <% terms.forEach(term => { %>
      <a class="card" href="<%= r('glossary/') %><%= term.slug %>/">
        <h3><%= term.title %></h3>
        <% if (term.summary) { %>
          <p><%= term.summary %></p>
        <% } %>
      </a>
    <% }); %>
    <% if (terms.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无术语</p>
      </div>
    <% } %>
  </div>
</section>

<script>
document.getElementById('searchInput').addEventListener('input', function(e) {
  const query = e.target.value.toLowerCase();
  document.querySelectorAll('.card').forEach(card => {
    const text = card.textContent.toLowerCase();
    card.style.display = text.includes(query) ? '' : 'none';
  });
});
</script>
