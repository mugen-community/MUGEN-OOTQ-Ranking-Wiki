<!DOCTYPE html>
<html lang="<%= lang || 'zh' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="<%= r('styles.css') %>">
  <link rel="stylesheet" href="<%= r('github-markdown.css') %>">
  <script src="<%= r('i18n-data.js') %>"></script>
  <script src="<%= r('i18n.js') %>" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" defer></script>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="<%= r('') %>" class="logo">
        <span>🎮</span>
        <span data-i18n="siteName">MUGEN OOTQ Wiki</span>
      </a>
      <div class="header-controls">
        <button id="themeToggle" class="btn" aria-label="Toggle theme">🌙</button>
        <select id="langSelect" class="lang-select"></select>
        <script>
        (function(){
          var names = window.__LANG_NAMES || {};
          var langs = window.__LANGS || ['zh','en','ja'];
          var sel = document.getElementById('langSelect');
          if (!sel) return;
          for (var i = 0; i < langs.length; i++) {
            var o = document.createElement('option');
            o.value = langs[i];
            o.textContent = names[langs[i]] || langs[i];
            sel.appendChild(o);
          }
        })();
        </script>
      </div>
    </div>
  </header>

  <nav class="container">
    <div style="padding: 10px 0; border-bottom: 1px solid var(--border-color); display: flex; gap: 20px; align-items: center;">
      <div style="flex: 1;">
        <a href="<%= r('') %>" data-i18n="home">首页</a>
        <a href="<%= r('characters/') %>" data-i18n="characters" style="margin-left: 15px;">角色</a>
        <a href="<%= r('glossary/') %>" data-i18n="glossary" style="margin-left: 15px;">术语</a>
      </div>
      <a href="https://github.com/mugen-community/MUGEN-OOTQ-Ranking-Wiki/issues/new?template=character_submission.md" class="btn" style="padding: 6px 14px; font-size: 0.9em;" data-i18n="newEntry"><img src="<%= r('github.svg') %>" alt="" style="height:1em;vertical-align:middle;margin-right:4px">新建</a>
    </div>
  </nav>

  <main class="container">
    <%- content %>
  </main>

  <footer>
    <div class="container">
      <p data-i18n="footer">&copy; 2026 MUGEN OOTQ Ranking Wiki</p>
    </div>
  </footer>
</body>
</html>
